{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Atlas-Sinal", "value": "U0lOQUw=" }
      ]
    },
    {
      "source": "/silencio.wav",
      "headers": [
        { "key": "Content-Type", "value": "audio/wav" },
        { "key": "Cache-Control", "value": "public, max-age=31536000" }
      ]
    }
  ],
  "routes": [
    { "src": "/404", "dest": "/404.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
